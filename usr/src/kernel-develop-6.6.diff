+	#size-cells = <0>;
+
+	panel: display@0{
+		compatible = "adafruit,yx240qv29", "ilitek,ili9341";
+		reg = <0>;
+		//spi-3wire;
+		spi-max-frequency = <50000000>;
+		dc-gpios = <&gpio0 RK_PA4 GPIO_ACTIVE_HIGH>;
+		reset-gpios = <&gpio1 RK_PC7 GPIO_ACTIVE_HIGH>;
+		rotation = <90>;
+		status = "okay";
